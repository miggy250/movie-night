# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TMDB_API_KEY: Required for fetching real movie data. 
# Get one at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY="YOUR_TMDB_API_KEY"

# TMDB_ACCESS_TOKEN: Required for Bearer Auth
VITE_TMDB_ACCESS_TOKEN="YOUR_TMDB_ACCESS_TOKEN"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mastercard Payment Gateway Credentials
# Get these from your Mastercard payment provider dashboard
VITE_MASTERCARD_API_KEY="YOUR_MASTERCARD_API_KEY"
VITE_MASTERCARD_MERCHANT_ID="YOUR_MERCHANT_ID"
VITE_MASTERCARD_SECRET_KEY="YOUR_SECRET_KEY"
VITE_MASTERCARD_WEBHOOK_SECRET="YOUR_WEBHOOK_SECRET"
VITE_MASTERCARD_ENV="sandbox" # Use "production" for live payments

# MomoPay Payment Credentials
# Get these from your MomoPay provider dashboard
VITE_MOMOPAY_API_KEY="YOUR_MOMOPAY_API_KEY"
VITE_MOMOPAY_MERCHANT_ID="YOUR_MOMOPAY_MERCHANT_ID"
VITE_MOMOPAY_SECRET_KEY="YOUR_MOMOPAY_SECRET_KEY"
VITE_MOMOPAY_CALLBACK_URL="https://yourdomain.com/payment/callback"
VITE_MOMOPAY_ENV="test" # Use "production" for live payments

# Payment Configuration
VITE_PAYMENT_CURRENCY="USD"
VITE_PAYMENT_SUCCESS_URL="https://yourdomain.com/payment/success"
VITE_PAYMENT_CANCEL_URL="https://yourdomain.com/payment/cancel"
